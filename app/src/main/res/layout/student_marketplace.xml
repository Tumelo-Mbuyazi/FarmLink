<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#4D000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=" Marketplace"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="3"
                android:shadowDy="3"
                android:shadowRadius="6"/>

            <!-- Cart Icon -->
            <ImageView
                android:id="@+id/btnCart"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_cart_white"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#80FFFFFF"
            android:layout_marginVertical="8dp"/>
    </LinearLayout>

    <!-- Search Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="20sp" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="Search crops or farmers..."
                android:background="@android:color/transparent"
                android:textColor="#424242"
                android:textColorHint="#9E9E9E"
                android:paddingVertical="4dp"
                android:textSize="14sp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Sort By Row -->
    <LinearLayout
        android:id="@+id/sortRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔽 SORT BY:"
            android:textColor="#E0F2F1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/sortDistance"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Distance"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#E8F5E9"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:layout_marginEnd="8dp"
            android:radius="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/sortPrice"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Price"
            android:textColor="#757575"
            android:textSize="13sp"
            android:background="#F0F0F0"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:layout_marginEnd="8dp"
            android:radius="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/sortLatest"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Latest"
            android:textColor="#757575"
            android:textSize="13sp"
            android:background="#F0F0F0"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:radius="16dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Results Count -->
    <TextView
        android:id="@+id/tvResults"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Loading products..."
        android:textColor="#E0F2F1"
        android:textSize="13sp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/sortRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Products RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/btnConnect"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvResults" />

    <!-- Connect Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConnect"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:text="🤝 Connect with Farmers"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#FF9800"
        app:cornerRadius="26dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="#4CAF50"
        app:itemTextColor="#4CAF50"
        app:itemRippleColor="#E8F5E9"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu_student"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Floating AI Button -->
    <!-- Floating AI Button -->
    <com.example.farmlink.FastDraggableFAB
        android:id="@+id/fabAI"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@drawable/ic_ai"
        app:backgroundTint="#4CAF50"
        app:tint="#FFFFFF"
        app:fabSize="normal"
        app:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>