<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:startColor="#4CAF50"
                android:endColor="#2E7D32"
                android:angle="45" />
            <corners android:radius="25dp" />
