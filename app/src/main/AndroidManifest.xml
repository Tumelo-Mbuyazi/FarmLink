<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FarmLink">

        <!-- Entry Point -->
        <activity
            android:name=".Auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth -->
        <activity android:name=".Auth.SignupActivity" />
        <activity android:name=".Auth.ForgotPasswordActivity" />

        <!-- Farmer Activities -->
        <activity android:name=".activities.farmer.FarmerDashboardActivity" />
        <activity android:name=".activities.farmer.FarmerProductsActivity" />
        <activity android:name=".activities.farmer.FarmerOrdersActivity" />
        <activity android:name=".activities.farmer.FarmerProfileActivity" />

        <!-- Student Activities -->
        <activity android:name=".activities.student.StudentDashboardActivity" />
        <activity android:name=".activities.student.StudentMarketplaceActivity" />
        <activity android:name=".activities.student.StudentLearningActivity" />
        <activity android:name=".activities.student.StudentProfileActivity" />
        <activity android:name=".activities.student.AskFarmerActivity" />
        <activity android:name=".activities.student.CourseDetailActivity" />
        <activity android:name=".activities.student.RequestFarmVisitActivity" />
        <activity android:name=".activities.student.StudentConnectActivity" />
        <activity
            android:name=".activities.student.ProductDetailActivity"
            android:exported="false" />

        <activity
            android:name=".activities.student.CheckoutActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.student.OrderConfirmationActivity"
            android:exported="false" />

        <activity
            android:name=".activities.student.MyOrdersActivity"
            android:exported="false" />

        <activity
            android:name=".activities.student.OrderTrackingActivity"
            android:exported="false" />

        <!-- Farmer Activities -->


        <activity
            android:name=".activities.farmer.AddProductActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.farmer.EditProductActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".activities.student.CartActivity" />

        <!-- AI Assistant -->
        <activity android:name=".StudentAIActivity" />


    </application>

</manifest>